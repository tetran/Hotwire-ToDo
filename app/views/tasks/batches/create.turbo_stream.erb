<% if @parent_task %>
  <%= turbo_stream.append "tasks", partial: "tasks/task", locals: { task: @parent_task.reload } %>
<% else %>
  <% @tasks.each do |task| %>
    <%= turbo_stream.append "tasks", partial: "tasks/task", locals: { task: } %>
  <% end %>
<% end %>
<%= turbo_stream.update Task.new, partial: "tasks/add_task_btn" %>
<%= turbo_stream.update "notification", partial: "shared/notification", locals: { message: t("controllers.tasks/batches.create.success", count: @tasks.length), status: "success" } %>
