<%= turbo_frame_tag "search_results" do %>
  <% if @query.present? %>
    <div class="search-results">
      <div class="search-results__header">
        <span class="search-results__count">
          <%= t("tasks.searches.index.results", count: @tasks.length, query: h(@query)) %>
        </span>
        <div class="search-results__filter">
          <%= link_to tasks_searches_path(q: @query, completed: !@show_completed),
                      class: "search-results__filter-toggle",
                      data: { turbo_frame: "search_results" } do %>
            <span class="material-symbols-outlined"><%= @show_completed ? "check_box" : "check_box_outline_blank" %></span>
            <%= t("tasks.searches.index.show_completed") %>
          <% end %>
        </div>
      </div>

      <% if @tasks.present? %>
        <ul class="search-results__list">
          <%= render partial: "tasks/searches/search_result", collection: @tasks, as: :task %>
        </ul>
      <% else %>
        <div class="search-results__empty">
          <%= t("tasks.searches.index.no_tasks_found") %>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
