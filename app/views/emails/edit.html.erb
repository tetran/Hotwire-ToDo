<%= turbo_frame_tag "modal" do %>
  <%= render "shared/modal", options: { base_class: "show-user", header_title: t("emails.edit.title") } do %>
    <% unless current_user.verified? %>
      <p class="show-user__item__description">
        <%= t("emails.edit.not_verified") %>
        <%= button_to t("emails.edit.verify_email"), email_verifications_path, class: "", data: { } %>
      </p>
      <hr>
    <% end %>
    <%= form_with model: current_user, url: email_path, data: { turbo_frame: "modal" } do |form| %>
      <% if current_user.errors.any? %>
        <%= render_errors_for current_user %>
      <% end %>

      <div class="show-user__item">
        <%= form.label :email %>
        <%= form.text_field :email, placeholder: t("emails.edit.new_email"), class: "full-width-input", data: { } %>
      </div>

      <div class="show-user__item">
        <%= form.label :password_challenge %>
        <%= form.password_field :password_challenge, placeholder: t("emails.edit.current_password"), class: "full-width-input", data: { } %>
      </div>

      <div class="form-actions">
        <%= link_to t("emails.edit.cancel"), user_path, class: "btn", data: { } %>
        <%= form.submit t("emails.edit.submit"), class: "primary" %>
      </div>
    <% end %>
  <% end %>
<% end %>
