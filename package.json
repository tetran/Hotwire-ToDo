{
  "name": "hobo",
  "version": "1.0.0",
  "description": "This is a sample todo list application to try Rails 7 & Hotwire.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "lib": "lib",
    "test": "test"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:coverage": "npx playwright test --project=chromium",
    "lint:js": "eslint app/javascript --ext .js,.ts,.tsx",
    "lint:js:fix": "eslint app/javascript --ext .js,.ts,.tsx --fix",
    "format": "prettier --write \"app/javascript/**/*.{js,ts,tsx}\" \"**/*.{css,scss,json,md}\"",
    "format:check": "prettier --check \"app/javascript/**/*.{js,ts,tsx}\" \"**/*.{css,scss,json,md}\""
  },
  "repository": {
    "type": "git",
    "url": "github-personal:tetran/Hotwire-ToDo.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "jsdom": "^29.0.1",
    "monocart-coverage-reports": "^2.12.9",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-ruby": "^5.2.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  }
}
